{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hive",
  "version": "0.4.0",
  "identifier": "com.taylorpratt.hive",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hive",
        "width": 1100,
        "height": 780
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "hive"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/thetaylorpratt/hive/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyRjFFMTM1NzYzRDRCMzUKUldRMVN6MTJOZUh4d3N5eTlRYjE0NlpBWTI5RGp4N0NCeHFLRVN4UU5hcmd2UFExU0prY3Z2ZDQK"
    }
  }
}