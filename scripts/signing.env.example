# Copy to ~/.hive/signing.env (chmod 600). Never commit real values.
# Cert name from: security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="Developer ID Application: Taylor Pratt (TEAMID1234)"
# Your Apple ID email
APPLE_ID="you@example.com"
# App-specific password from appleid.apple.com → Sign-In & Security
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# Team ID from developer.apple.com/account → Membership
APPLE_TEAM_ID="TEAMID1234"
